{
  "name": "@docbox/server",
  "private": true,
  "version": "0.2.0",
  "description": "docBox control-plane server — serves the domain world and live event stream",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:audit": "node dist/audit/ingest.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "DOCBOX_NO_LISTEN=1 vitest run",
    "test:coverage": "DOCBOX_NO_LISTEN=1 vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.10.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  }
}
