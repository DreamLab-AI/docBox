# docBox environment template. Copy to `.env` and fill in — `.env` is never
# committed. Every variable the compose stack (compose.yaml + compose.tunnel.yaml)
# and init-firewall.sh read is listed here with a one-line note.
#
#   cp .env.example .env

# --- Image coordinates -----------------------------------------------------
DOCBOX_REGISTRY=docbox                 # registry/namespace for built images (local OCI registry in prod)
DOCBOX_TAG=dev                         # image tag; rebuild.sh sets this to the git SHA on an overhaul

# --- Toolchain bundle gates (mirror foreman.toml [toolchain]) --------------
# The control plane writes these from foreman.toml on a rebuild-class change.
TS_DASHBOARD=1                         # 1|0 — Biome/Vite/Vitest/Playwright bundle
PYTHON=1                               # 1|0 — uv + Pythons + JupyterLab + papermill bundle
TYPESETTING=typst                      # off|typst|full-latex — typesetting bundle
PLAYWRIGHT_BROWSERS=1                  # 1|0 — bake Chromium for the team's own E2E tests

# --- Loopback host ports (bound to 127.0.0.1 only) -------------------------
FOREMAN_PORT=8443                      # oauth2-proxy entry the tunnel targets
CONTROL_PLANE_PORT=8788                # Foreman control-plane, direct loopback (admin/debug)
CODE_SERVER_PORT=8080                  # code-server editor, loopback (proxied in prod)

# --- Provider API keys (metered console keys only; never subscription OAuth) -
ANTHROPIC_API_KEY=sk-ant-replace-me    # referenced by foreman.toml providers.anthropic.key_ref
OPENAI_API_KEY=sk-replace-me           # referenced by foreman.toml providers.openai.key_ref
# DEEPSEEK_API_KEY=                    # only if providers.deepseek.enabled = true
# GLM_API_KEY=                         # only if providers.glm.enabled = true

# --- Microsoft Entra SSO (oauth2-proxy ms-entra-id provider) ---------------
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000   # Entra directory (tenant) ID
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000   # app registration client ID
ENTRA_CLIENT_SECRET=replace-me                          # client secret (expires ≤24 months — rotate)
OAUTH2_PROXY_COOKIE_SECRET=replace-with-32-byte-base64  # `openssl rand -base64 32`

# --- Audit -----------------------------------------------------------------
AUDIT_ANCHOR_INTERVAL_MIN=60           # how often the audit chain head is signed off-box

# --- Egress firewall (init-firewall.sh) ------------------------------------
# Space- or comma-separated allowlist. If unset, init-firewall.sh falls back to
# reading egress_allowlist from foreman.toml.
EGRESS_ALLOWLIST="api.anthropic.com api.openai.com registry.npmjs.org pypi.org files.pythonhosted.org github.com objects.githubusercontent.com"
DNS_SERVER=1.1.1.1                     # resolver the firewall permits + uses to resolve the allowlist

# --- Sidecar images --------------------------------------------------------
OAUTH2_PROXY_IMAGE=quay.io/oauth2-proxy/oauth2-proxy:v7.7.1   # pin by digest in prod
BROWSER_IMAGE=zenika/alpine-chrome:124   # confined chrome sidecar (MIT); pin by digest. NB: browserless/chromium is SSPL, do not use.

# --- Vault key source (corpus/05 encrypted-vaults) -------------------------
# AZURE_KEYVAULT_URL=https://<vault>.vault.azure.net/          # when vaults.key_source = azure-kv
# OPENBAO_ADDR=http://openbao:8200                             # when vaults.key_source = openbao

# --- Tunnel overlay (compose.tunnel.yaml) ----------------------------------
CLOUDFLARED_TOKEN=replace-me           # named-tunnel token from the Cloudflare Zero Trust dashboard
CLOUDFLARED_IMAGE=cloudflare/cloudflared:2025.7.0             # pin by digest in prod

# --- Optional: Tailscale for OUR ops mesh (not a client-facing service) -----
# TAILSCALE_AUTHKEY=tskey-auth-replace-me   # only if an ops-mesh overlay is added
